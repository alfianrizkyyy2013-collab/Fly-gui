-- ============ SLIDER LOGIC ============
local isDragging = false

local function updateSlider(input)
    local ratio = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
    flySpeed = math.floor(ratio * 295) + 5 -- Range 5 - 300
    sliderFill.Size = UDim2.new(ratio, 0, 1, 0)
    sliderKnob.Position = UDim2.new(ratio, -8, 0.5, -8)
    speedLabel.Text = "Speed: " .. flySpeed
end

sliderKnob.MouseButton1Down:Connect(function() isDragging = true end)
UserInputService.InputEnded:Connect(function(input) 
    if input.UserInputType == Enum.UserInputType.MouseButton1 then isDragging = false end 
end)
UserInputService.InputChanged:Connect(function(input)
    if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        updateSlider(input)
    end
end)

-- ============ FLY LOGIC ============
local function startFly()
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    local hum = char:WaitForChild("Humanoid")

    -- Setup Physics
    local bg = Instance.new("BodyGyro", hrp) -- Tetap gunakan BodyGyro karena lebih simple untuk kamera
    bg.P = 9e4
    bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    bg.CFrame = hrp.CFrame

    local bv = Instance.new("BodyVelocity", hrp)
    bv.Velocity = Vector3.new(0,0,0)
    bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)

    hum.PlatformStand = true

    flyConnection = RunService.RenderStepped:Connect(function()
        if not isFlying or not hrp.Parent then
            bv:Destroy()
            bg:Destroy()
            hum.PlatformStand = false
            if flyConnection then flyConnection:Disconnect() end
            return
        end

        local moveDir = Vector3.new(0,0,0)
        local camCF = camera.CFrame
        
        -- Input Check
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += camCF.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= camCF.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= camCF.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += camCF.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir -= Vector3.new(0, 1, 0) end

        if moveDir.Magnitude > 0 then
            bv.Velocity = moveDir.Unit * flySpeed
        else
            bv.Velocity = Vector3.new(0, 0, 0)
        end
        
        bg.CFrame = camCF
    end)
end

-- ============ TOGGLE LOGIC ============
toggleBtn.MouseButton1Click:Connect(function()
    isFlying = not isFlying
    if isFlying then
        toggleBtn.Text = "⏹  FLY: ON"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        startFly()
    else
        toggleBtn.Text = "▶  FLY: OFF"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 100)
    end
end)

-- Hotkey 'F' untuk toggle cepat
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.F then
        toggleBtn.Text = isFlying and "▶  FLY: OFF" or "⏹  FLY: ON"
        isFlying = not isFlying
        if isFlying then startFly() end
    end
end)
